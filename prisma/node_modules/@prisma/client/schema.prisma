datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
  output   = "./node_modules/@prisma/client"
}

enum Role {
  STUDENT
  LECTURER
}

model User {
  id             Int              @id @default(autoincrement())
  name           String
  email          String           @unique
  password       String
  role           Role
  subjects       Subject[]        @relation("UserSubjects")
  assignments    Assignment[] // Assignments created by lecturer
  submissions    Submission[] // Assignments submitted by student
  quizzesCreated Quiz[]           @relation("UserQuizLecturer") // <-- Required!
  quizzes        QuizSubmission[]
  lectures       Lecture[]        @relation("LecturerLectures")
}

model Subject {
  id          Int          @id @default(autoincrement())
  name        String
  students    User[]       @relation("UserSubjects")
  lectures    Lecture[]
  assignments Assignment[]
  quizzes     Quiz[]
}

model Lecture {
  id         Int     @id @default(autoincrement())
  title      String
  content    String
  subject    Subject @relation(fields: [subjectId], references: [id])
  subjectId  Int
  lecturer   User    @relation("LecturerLectures", fields: [lecturerId], references: [id])
  lecturerId Int
}

model Assignment {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  subject     Subject      @relation(fields: [subjectId], references: [id])
  subjectId   Int
  lecturer    User         @relation(fields: [lecturerId], references: [id])
  lecturerId  Int
  submissions Submission[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId Int
  student      User       @relation(fields: [studentId], references: [id])
  studentId    Int
  content      String
  grade        Int?
}

model Quiz {
  id          Int              @id @default(autoincrement())
  question    String
  answer      String
  subject     Subject          @relation(fields: [subjectId], references: [id])
  subjectId   Int
  lecturer    User             @relation("UserQuizLecturer", fields: [lecturerId], references: [id])
  lecturerId  Int
  deadline    DateTime
  submissions QuizSubmission[]
}

model QuizSubmission {
  id        Int      @id @default(autoincrement())
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  quizId    Int
  student   User     @relation(fields: [studentId], references: [id])
  studentId Int
  attempt   String
  timestamp DateTime @default(now())
}
